<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<Project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="project_projx.xsd">

  <SchemaVersion>2.1</SchemaVersion>
  <Header>### uVision Project - ORKO Slave Node - Orman Yangini Erken Tespit</Header>

  <Targets>
    <Target>
      <TargetName>ORKO_Sim</TargetName>
      <ToolsetNumber>0x4</ToolsetNumber>
      <ToolsetName>ARM-ADS</ToolsetName>
      <uAC6>0</uAC6>

      <TargetOption>
        <TargetCommonOption>
          <Device>M031FB0AE</Device>
          <Vendor>Nuvoton</Vendor>
          <Cpu>IRAM(0x20000000,0x8000) IROM(0x00000000,0x20000) CPUTYPE("Cortex-M0") CLOCK(12000000) ELITTLE</Cpu>
          <OutputDirectory>.\build\</OutputDirectory>
          <OutputName>orko_sim</OutputName>
          <CreateExecutable>1</CreateExecutable>
          <CreateLib>0</CreateLib>
          <CreateHexFile>1</CreateHexFile>
          <DebugInformation>1</DebugInformation>
          <BrowseInformation>0</BrowseInformation>
          <ListingPath>.\build\</ListingPath>
          <HexFormatSelection>1</HexFormatSelection>
          <TargetStatus>
            <Error>0</Error>
            <ExitCodeStop>0</ExitCodeStop>
            <ButtonStop>0</ButtonStop>
            <NotGenerated>0</NotGenerated>
            <InvalidFlash>1</InvalidFlash>
          </TargetStatus>
        </TargetCommonOption>

        <CommonProperty>
          <UseCPPCompiler>0</UseCPPCompiler>
          <IncludeInBuild>1</IncludeInBuild>
          <AlwaysBuild>0</AlwaysBuild>
          <GenerateAssemblyFile>0</GenerateAssemblyFile>
          <AssembleAssemblyFile>0</AssembleAssemblyFile>
          <PublicsOnly>0</PublicsOnly>
          <StopOnExitCode>3</StopOnExitCode>
        </CommonProperty>

        <DllOption>
          <SimDllName>SARMCM3.DLL</SimDllName>
          <SimDllArguments>-REMAP -MPU</SimDllArguments>
          <SimDlgDll>DCM.DLL</SimDlgDll>
          <SimDlgDllArguments>-pCM0</SimDlgDllArguments>
          <TargetDllName>SARMCM3.DLL</TargetDllName>
          <TargetDllArguments>-MPU</TargetDllArguments>
          <TargetDlgDll>TCM.DLL</TargetDlgDll>
          <TargetDlgDllArguments>-pCM0</TargetDlgDllArguments>
        </DllOption>

        <TargetArmAds>
          <ArmAdsMisc>
            <BigEnd>0</BigEnd>
            <AdsCpuType>"Cortex-M0"</AdsCpuType>
            <OnChipMemories>
              <IRAM>
                <Type>0</Type>
                <StartAddress>0x20000000</StartAddress>
                <Size>0x8000</Size>
              </IRAM>
              <IROM>
                <Type>1</Type>
                <StartAddress>0x0</StartAddress>
                <Size>0x20000</Size>
              </IROM>
            </OnChipMemories>
          </ArmAdsMisc>

          <Cads>
            <interw>1</interw>
            <Optim>1</Optim>
            <oTime>0</oTime>
            <OneElfS>1</OneElfS>
            <uThumb>1</uThumb>
            <uC99>1</uC99>
            <VariousControls>
              <MiscControls></MiscControls>
              <Define>ORKO_SIM</Define>
              <Undefine></Undefine>
              <IncludePath>.\app;.\algo;.\sim;.\drivers;.\sensors;.\lora;.\power</IncludePath>
            </VariousControls>
          </Cads>

          <Aads>
            <interw>1</interw>
            <thumb>1</thumb>
            <VariousControls>
              <MiscControls></MiscControls>
              <Define></Define>
              <Undefine></Undefine>
              <IncludePath></IncludePath>
            </VariousControls>
          </Aads>

          <LDads>
            <umfTarg>0</umfTarg>
            <noStLib>0</noStLib>
            <RepFail>1</RepFail>
            <useFile>0</useFile>
            <TextAddressRange>0x00000000</TextAddressRange>
            <DataAddressRange>0x20000000</DataAddressRange>
            <ScatterFile></ScatterFile>
            <Misc></Misc>
          </LDads>
        </TargetArmAds>
      </TargetOption>

      <Groups>

        <Group>
          <GroupName>Algorithm</GroupName>
          <Files>
            <File>
              <FileName>fire_score.c</FileName>
              <FileType>1</FileType>
              <FilePath>.\algo\fire_score.c</FilePath>
            </File>
            <File>
              <FileName>fire_score.h</FileName>
              <FileType>5</FileType>
              <FilePath>.\algo\fire_score.h</FilePath>
            </File>
          </Files>
        </Group>

        <Group>
          <GroupName>Application</GroupName>
          <Files>
            <File>
              <FileName>orko_config.h</FileName>
              <FileType>5</FileType>
              <FilePath>.\app\orko_config.h</FilePath>
            </File>
            <File>
              <FileName>main.c</FileName>
              <FileType>1</FileType>
              <FilePath>.\app\main.c</FilePath>
            </File>
          </Files>
        </Group>

        <Group>
          <GroupName>Simulation</GroupName>
          <Files>
            <File>
              <FileName>sim_main.c</FileName>
              <FileType>1</FileType>
              <FilePath>.\sim\sim_main.c</FilePath>
            </File>
            <File>
              <FileName>sim_display.c</FileName>
              <FileType>1</FileType>
              <FilePath>.\sim\sim_display.c</FilePath>
            </File>
            <File>
              <FileName>sim_display.h</FileName>
              <FileType>5</FileType>
              <FilePath>.\sim\sim_display.h</FilePath>
            </File>
            <File>
              <FileName>fake_sensors.c</FileName>
              <FileType>1</FileType>
              <FilePath>.\sim\fake_sensors.c</FilePath>
            </File>
            <File>
              <FileName>fake_sensors.h</FileName>
              <FileType>5</FileType>
              <FilePath>.\sim\fake_sensors.h</FilePath>
            </File>
            <File>
              <FileName>sim_uart.c</FileName>
              <FileType>1</FileType>
              <FilePath>.\sim\sim_uart.c</FilePath>
            </File>
          </Files>
        </Group>

        <Group>
          <GroupName>Sensors</GroupName>
          <Files>
            <File>
              <FileName>drv_bmp390.c</FileName>
              <FileType>1</FileType>
              <FilePath>.\sensors\drv_bmp390.c</FilePath>
            </File>
            <File>
              <FileName>drv_bmp390.h</FileName>
              <FileType>5</FileType>
              <FilePath>.\sensors\drv_bmp390.h</FilePath>
            </File>
            <File>
              <FileName>drv_hdc2022.c</FileName>
              <FileType>1</FileType>
              <FilePath>.\sensors\drv_hdc2022.c</FilePath>
            </File>
            <File>
              <FileName>drv_hdc2022.h</FileName>
              <FileType>5</FileType>
              <FilePath>.\sensors\drv_hdc2022.h</FilePath>
            </File>
            <File>
              <FileName>drv_mq9.c</FileName>
              <FileType>1</FileType>
              <FilePath>.\sensors\drv_mq9.c</FilePath>
            </File>
            <File>
              <FileName>drv_mq9.h</FileName>
              <FileType>5</FileType>
              <FilePath>.\sensors\drv_mq9.h</FilePath>
            </File>
            <File>
              <FileName>drv_neo7m.c</FileName>
              <FileType>1</FileType>
              <FilePath>.\sensors\drv_neo7m.c</FilePath>
            </File>
            <File>
              <FileName>drv_neo7m.h</FileName>
              <FileType>5</FileType>
              <FilePath>.\sensors\drv_neo7m.h</FilePath>
            </File>
            <File>
              <FileName>drv_scd40.c</FileName>
              <FileType>1</FileType>
              <FilePath>.\sensors\drv_scd40.c</FilePath>
            </File>
            <File>
              <FileName>drv_scd40.h</FileName>
              <FileType>5</FileType>
              <FilePath>.\sensors\drv_scd40.h</FilePath>
            </File>
          </Files>
        </Group>

        <Group>
          <GroupName>Drivers</GroupName>
          <Files>
            <File>
              <FileName>hal_adc.c</FileName>
              <FileType>1</FileType>
              <FilePath>.\drivers\hal_adc.c</FilePath>
            </File>
            <File>
              <FileName>hal_adc.h</FileName>
              <FileType>5</FileType>
              <FilePath>.\drivers\hal_adc.h</FilePath>
            </File>
            <File>
              <FileName>hal_i2c.c</FileName>
              <FileType>1</FileType>
              <FilePath>.\drivers\hal_i2c.c</FilePath>
            </File>
            <File>
              <FileName>hal_i2c.h</FileName>
              <FileType>5</FileType>
              <FilePath>.\drivers\hal_i2c.h</FilePath>
            </File>
            <File>
              <FileName>hal_timer.c</FileName>
              <FileType>1</FileType>
              <FilePath>.\drivers\hal_timer.c</FilePath>
            </File>
            <File>
              <FileName>hal_timer.h</FileName>
              <FileType>5</FileType>
              <FilePath>.\drivers\hal_timer.h</FilePath>
            </File>
            <File>
              <FileName>hal_uart.c</FileName>
              <FileType>1</FileType>
              <FilePath>.\drivers\hal_uart.c</FilePath>
            </File>
            <File>
              <FileName>hal_uart.h</FileName>
              <FileType>5</FileType>
              <FilePath>.\drivers\hal_uart.h</FilePath>
            </File>
          </Files>
        </Group>

        <Group>
          <GroupName>LoRa</GroupName>
          <Files>
            <File>
              <FileName>lora_e22.c</FileName>
              <FileType>1</FileType>
              <FilePath>.\lora\lora_e22.c</FilePath>
            </File>
            <File>
              <FileName>lora_e22.h</FileName>
              <FileType>5</FileType>
              <FilePath>.\lora\lora_e22.h</FilePath>
            </File>
          </Files>
        </Group>

        <Group>
          <GroupName>Power</GroupName>
          <Files>
            <File>
              <FileName>power_mgmt.c</FileName>
              <FileType>1</FileType>
              <FilePath>.\power\power_mgmt.c</FilePath>
            </File>
            <File>
              <FileName>power_mgmt.h</FileName>
              <FileType>5</FileType>
              <FilePath>.\power\power_mgmt.h</FilePath>
            </File>
          </Files>
        </Group>

        <Group>
          <GroupName>Startup</GroupName>
          <Files>
            <File>
              <FileName>startup_M031Series.s</FileName>
              <FileType>2</FileType>
              <FilePath>.\startup\startup_M031Series.s</FilePath>
            </File>
          </Files>
        </Group>

      </Groups>

    </Target>
  </Targets>

</Project>
